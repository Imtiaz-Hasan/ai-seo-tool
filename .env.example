APP_NAME=Scribe
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Demo mode: AI runs on a built-in MOCK model - fully usable with NO API key.
# Set to false once you configure a real provider below.
# ---------------------------------------------------------------------------
DEMO_MODE=true

# ---------------------------------------------------------------------------
# Demo / first account, seeded on boot. CHANGE before deploying anywhere.
# ---------------------------------------------------------------------------
ADMIN_NAME="Demo User"
ADMIN_EMAIL=demo@example.com
ADMIN_PASSWORD=password

# ---------------------------------------------------------------------------
# LLM provider: mock | openai | anthropic | ollama
# The app falls back to "mock" automatically if the chosen provider has no key.
# ---------------------------------------------------------------------------
LLM_PROVIDER=mock
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# OpenAI (or any OpenAI-compatible endpoint)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Ollama (local models - no key). Use `docker compose --profile ollama up`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ---------------------------------------------------------------------------
# Database (MySQL). Defaults target the Docker Compose "db" service.
# For local non-Docker dev set DB_HOST=127.0.0.1.
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=scribe
DB_USERNAME=scribe
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
